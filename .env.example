
# --- Model provider keys (at least one required) ---
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...



# Durable workflow runtime (disable only for tests/debugging)
#JOB_APPLI_DBOS_ENABLED=true
#JOB_APPLI_DBOS_APP_NAME=job-appli

# --- LLM routing ---

#LLM_DEFAULT_MODEL=openai:gpt-5.6-terra


#LLM_FALLBACK_MODEL=
#   resume_extraction      parse resume text into the draft profile
#   onboarding_interview   generate adaptive onboarding questions
#   listing_normalization  raw job listing -> canonical job record
#   fit_evaluation         reasoned job-fit assessment
#   dedupe_adjudication    ambiguous duplicate-listing pairs
#   question_classification classify application questions by answer type
#   employer_research      summarize employer/product research
#   answer_generation      grounded narrative application answers
#   cover_letter           policy-driven cover-letter drafting
#   content_review         optional second-pass answer reviewer
#   page_classification    cheap browser page/state classification
#   browser_navigation     browser agent action decisions                  (P


# Example, everything explicit:
#LLM_TASK_MODELS={"resume_extraction":"openai:gpt-5-mini","onboarding_interview":"openai:gpt-5-mini","listing_normalization":"openai:gpt-5-mini","fit_evaluation":"openai:gpt-5.2","dedupe_adjudication":"openai:gpt-5-mini","question_classification":"openai:gpt-5-mini","employer_research":"openai:gpt-5.2","answer_generation":"openai:gpt-5.2","cover_letter":"openai:gpt-5.2","content_review":"openai:gpt-5.2","page_classification":"openai:gpt-5-mini","browser_navigation":"openai:gpt-5.2"}
# Retry budgets (transport = provider SDK, validation = schema repair)


#LLM_TRANSPORT_RETRIES=2
#LLM_VALIDATION_RETRIES=1

#JOB_APPLI_LOG_LEVEL=INFO
